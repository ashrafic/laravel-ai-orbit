{
    "name": "ashrafic/laravel-ai-orbit",
    "description": "The Intelligent Control Tower for Laravel AI SDK.",
    "keywords": [
        "laravel",
        "ai",
        "orbit",
        "observability",
        "agent",
        "playground",
        "arena",
        "audit",
        "analytics",
        "debugging",
        "export",
        "prompts",
        "pricing",
        "monitoring"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Ashrafic Labs",
            "email": "hello@ashraficlabs.com",
            "homepage": "https://ashraficlabs.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/ai": "^0.6",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Ashrafic\\AiOrbit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ashrafic\\AiOrbit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ashrafic\\AiOrbit\\OrbitServiceProvider"
            ]
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "lint": "pint",
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
