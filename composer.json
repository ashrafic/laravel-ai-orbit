{
    "name": "ashraful19/laravel-ai-orbit",
    "description": "Observability, management, and developer playground for the Laravel AI SDK.",
    "keywords": [
        "laravel",
        "ai",
        "orbit",
        "observability",
        "agent",
        "playground"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Ashraful Islam Tushar",
            "email": "ashrafulislamtushar@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/ai": "^0.6",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Ashraf\\Orbit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ashraf\\Orbit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ashraf\\Orbit\\OrbitServiceProvider"
            ]
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "lint": "pint",
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
